@model LoginViewModel
@{
    ViewData["Title"] = "Login";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SAS Job Runner</title>

    @* DevExtreme CSS (light theme) *@
    <link rel="stylesheet" href="https://cdn3.devexpress.com/jslib/25.1.7/css/dx.light.css" />

    <style>
        html, body {
            height: 100%;
            margin: 0;
            padding: 0;
            background: #f5f5f5;
            font-family: "Segoe UI", Arial, sans-serif;
        }

        .login-wrapper {
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
        }

        .login-card {
            background: #fff;
            border-radius: 6px;
            box-shadow: 0 2px 12px rgba(0,0,0,.15);
            padding: 40px 48px;
            width: 360px;
        }

        .login-card h1 {
            font-size: 1.4rem;
            margin: 0 0 24px;
            text-align: center;
            color: #333;
        }

        .login-error {
            background: #fff3f3;
            border: 1px solid #f5c6cb;
            border-radius: 4px;
            color: #721c24;
            font-size: 0.875rem;
            margin-bottom: 16px;
            padding: 10px 14px;
        }

        .login-submit {
            margin-top: 20px;
        }
    </style>
</head>
<body>
    <div class="login-wrapper">
        <div class="login-card">
            <h1>SAS Job Runner</h1>

            @* Error area — visible only when ErrorMessage is populated (Req 1.4, 1.5) *@
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div id="errorMessage" class="login-error" role="alert">@Model.ErrorMessage</div>
            }
            else
            {
                <div id="errorMessage" class="login-error" role="alert" style="display:none;"></div>
            }

            @* DevExtreme form container (Req 1.1) *@
            <div id="loginForm"></div>

            <div class="login-submit">
                <div id="btnLogin"></div>
            </div>
        </div>
    </div>

    @* DevExtreme JS *@
    <script src="https://cdn3.devexpress.com/jslib/25.1.7/js/dx.all.js"></script>

    <script>
        (function () {
            // Initialise the DevExtreme dxForm with username and password fields.
            new DevExpress.ui.dxForm(document.getElementById('loginForm'), {
                formData: { username: '', password: '' },
                items: [
                    {
                        dataField: 'username',
                        label: { text: 'Username' },
                        editorType: 'dxTextBox',
                        editorOptions: { placeholder: 'Enter username' },
                        validationRules: [{ type: 'required', message: 'Username is required.' }]
                    },
                    {
                        dataField: 'password',
                        label: { text: 'Password' },
                        editorType: 'dxTextBox',
                        editorOptions: {
                            mode: 'password',
                            placeholder: 'Enter password'
                        },
                        validationRules: [{ type: 'required', message: 'Password is required.' }]
                    }
                ]
            });

            // Initialise the Login button.
            new DevExpress.ui.dxButton(document.getElementById('btnLogin'), {
                text: 'Login',
                type: 'default',
                width: '100%',
                onClick: function () {
                    if (typeof window.loginSubmitHandler === 'function') {
                        window.loginSubmitHandler();
                    }
                }
            });
        }());
    </script>

    @* Login form submit handler (Task 10.1) *@
    <script src="~/js/login.js"></script>
</body>
</html>
