@{
    ViewData["Title"] = "Batch Run";
}

@section Styles {
    <style>
        .placeholder-card {
            max-width: 520px;
            margin: 60px auto;
            text-align: center;
            padding: 48px 40px;
            background: #fff;
            border: 1px solid #e0e0e0;
            border-radius: 8px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.06);
        }

        .placeholder-icon {
            font-size: 3rem;
            margin-bottom: 16px;
            color: #58a6ff;
        }

        .placeholder-card h2 {
            font-size: 1.4rem;
            font-weight: 600;
            margin-bottom: 10px;
            color: #1a1a2e;
        }

        .placeholder-card p {
            color: #666;
            font-size: 0.95rem;
            margin: 0;
        }
    </style>
}

<div class="placeholder-card">
    <div class="placeholder-icon">&#9654;&#9654;</div>
    <h2>Batch Run</h2>
    <p>This screen is coming soon. Batch job scheduling and management will be available here.</p>
</div>
