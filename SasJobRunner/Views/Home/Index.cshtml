@using Microsoft.AspNetCore.Antiforgery
@inject IAntiforgery Antiforgery
@{
    ViewData["Title"] = "Configure Output";
    var tokens = Antiforgery.GetAndStoreTokens(Context);
}

@section Styles {
    @* DevExtreme CSS *@
    <link rel="stylesheet" href="~/lib/devextreme/css/dx.light.css" />

    @* Anti-forgery token for fetch() calls — placed in <head> so it's always accessible (Req 7.6) *@
    <meta name="RequestVerificationToken" content="@tokens.RequestToken" />

    <style>
        /* ── Page layout ─────────────────────────────────────────── */
        .page-content {
            display: flex;
            flex-direction: column;
            gap: 12px;
            padding: 12px 0;
        }

        /* ── Toolbar ─────────────────────────────────────────────── */
        .toolbar-row {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        /* ── Monaco editor container (Req 2.3) ───────────────────── */
        #monacoContainer {
            min-height: 50vh;
            height: 55vh;
            border: 1px solid #ddd;
            border-radius: 4px;
            overflow: hidden;
        }

        /* ── Log content inside the tab panel ───────────────────── */
        #logContent {
            margin: 0;
            padding: 8px 12px;
            font-family: "Consolas", "Courier New", monospace;
            font-size: 0.85rem;
            white-space: pre-wrap;
            word-break: break-all;
            overflow-y: auto;
            max-height: 30vh;
            min-height: 120px;
            background: #1e1e1e;
            color: #d4d4d4;
        }
    </style>
}

@* Anti-forgery token moved to @section Styles (inside <head>) *@

<div class="page-content">

    @* ── Toolbar: Create / Run / Cancel / Logout buttons ── *@
    <div class="toolbar-row">
        <div id="btnCreate"></div>
        <div id="btnRun"></div>
        <div id="btnCancel"></div>
        <div id="btnLogout" style="margin-left:auto;"></div>
    </div>

    @* ── Monaco editor (Req 2.3, 2.4, 2.9) ── *@
    <div id="monacoContainer"></div>

    @* ── Tab panel with Log tab (Req 2.5, 2.8, 2.10) ── *@
    <div id="logTabPanel"></div>

</div>

@section Scripts {
    @* DevExtreme JS (local — no CDN dependency) *@
    <script src="~/lib/devextreme/js/dx.all.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            try {
                // ── Create button ─────────────────────────────────────────────
                new DevExpress.ui.dxButton(document.getElementById('btnCreate'), {
                    text: 'Create',
                    type: 'default',
                    disabled: false,
                    onClick: function () {
                        if (typeof window.onCreateClick === 'function') window.onCreateClick();
                    }
                });

                // ── Run button (disabled until a job is created) ──────────────
                new DevExpress.ui.dxButton(document.getElementById('btnRun'), {
                    text: 'Run',
                    type: 'success',
                    disabled: true,
                    onClick: function () {
                        if (typeof window.onRunClick === 'function') window.onRunClick();
                    }
                });

                // ── Cancel button ─────────────────────────────────────────────
                new DevExpress.ui.dxButton(document.getElementById('btnCancel'), {
                    text: 'Cancel',
                    type: 'danger',
                    disabled: true,
                    onClick: function () {
                        if (typeof window.onCancelClick === 'function') window.onCancelClick();
                    }
                });

                // ── Logout button ─────────────────────────────────────────────
                new DevExpress.ui.dxButton(document.getElementById('btnLogout'), {
                    text: 'Logout',
                    type: 'normal',
                    onClick: function () {
                        if (typeof window.onLogoutClick === 'function') window.onLogoutClick();
                    }
                });

                // ── Log tab panel ─────────────────────────────────────────────
                new DevExpress.ui.dxTabPanel(document.getElementById('logTabPanel'), {
                    items: [{
                        title: 'Log',
                        template: function () { return '<pre id="logContent"></pre>'; }
                    }],
                    selectedIndex: 0,
                    animationEnabled: false
                });
            } catch (e) {
                console.error('DevExtreme widget init failed:', e);
            }
        });
    </script>

    @* Monaco Editor CDN loader *@
    <script src="https://cdn.jsdelivr.net/npm/monaco-editor@0.52.0/min/vs/loader.js"></script>

    @* Configure Output client logic *@
    <script src="~/js/configure-output.js" asp-append-version="true"></script>
}
