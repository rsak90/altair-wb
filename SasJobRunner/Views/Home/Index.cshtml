@using Microsoft.AspNetCore.Antiforgery
@inject IAntiforgery Antiforgery
@{
    ViewData["Title"] = "Output";
    var tokens = Antiforgery.GetAndStoreTokens(Context);
}

@section Styles {
    @* DevExtreme CSS *@
    <link rel="stylesheet" href="~/lib/devextreme/css/dx.light.css" />

    @* Anti-forgery token for fetch() calls — placed in <head> so it's always accessible (Req 7.6) *@
    <meta name="RequestVerificationToken" content="@tokens.RequestToken" />

    <style>
        /* ── Page layout ─────────────────────────────────────────── */
        .page-content {
            display: flex;
            flex-direction: column;
            gap: 12px;
            padding: 12px 0;
        }

        /* ── Toolbar ─────────────────────────────────────────────── */
        .toolbar-row {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        /* ── Main tab panel ──────────────────────────────────────── */
        #mainTabPanel {
            flex: 1;
        }

        /* ── Monaco editor container (Req 2.3) ───────────────────── */
        #monacoContainer {
            height: 60vh;
            border: none;
            overflow: hidden;
        }

        /* ── Tab content areas ───────────────────────────────────── */
        .tab-pane-output,
        .tab-pane-files {
            padding: 12px;
            min-height: 200px;
            color: #555;
            font-size: 0.9rem;
        }

        /* ── Log content inside the tab panel ───────────────────── */
        #logContent {
            margin: 0;
            padding: 8px 12px;
            font-family: "Consolas", "Courier New", monospace;
            font-size: 0.85rem;
            white-space: pre-wrap;
            word-break: break-all;
            overflow-y: auto;
            height: 60vh;
            min-height: 120px;
            background: #1e1e1e;
            color: #d4d4d4;
        }

        /* ── Debug info bar ──────────────────────────────────────── */
        .debug-info {
            display: flex;
            gap: 16px;
            padding: 6px 12px;
            background: #f0f0f0;
            border: 1px solid #ddd;
            border-radius: 4px;
            font-size: 0.85rem;
            color: #333;
            font-family: "Consolas", "Courier New", monospace;
        }

        .debug-info span {
            display: inline-block;
        }

        .debug-info .label {
            font-weight: 600;
            color: #555;
        }

        /* ── Loader overlay ──────────────────────────────────────── */
        .loader-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.4);
            z-index: 9999;
            align-items: center;
            justify-content: center;
        }

        .loader-overlay.active {
            display: flex;
        }

        .loader-spinner {
            width: 50px;
            height: 50px;
            border: 5px solid #f3f3f3;
            border-top: 5px solid #3498db;
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }

        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
    </style>
}

@* Anti-forgery token moved to @section Styles (inside <head>) *@

<div class="page-content">

    @* ── Toolbar: Create / Run / Cancel / Logout buttons ── *@
    <div class="toolbar-row">
        <div id="btnCreate"></div>
        <div id="btnRun"></div>
        <div id="btnCancel"></div>
        <div id="btnLogout" style="margin-left:auto;"></div>
    </div>

    @* ── Debug info bar (Job ID and Status) ── *@
    <div class="debug-info">
        <span><span class="label">Job ID:</span> <span id="debugJobId">—</span></span>
        <span><span class="label">Status:</span> <span id="debugJobStatus">—</span></span>
    </div>

    @* ── Main tab panel: Program / Output / Files / Log ── *@
    <div id="mainTabPanel"></div>

</div>

@* ── Loader overlay ── *@
<div class="loader-overlay" id="loaderOverlay">
    <div class="loader-spinner"></div>
</div>

@section Scripts {
    @* DevExtreme JS (local — no CDN dependency) *@
    <script src="~/lib/devextreme/js/dx.all.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            try {
                // ── Create button ─────────────────────────────────────────────
                new DevExpress.ui.dxButton(document.getElementById('btnCreate'), {
                    text: 'Create',
                    type: 'default',
                    disabled: false,
                    onClick: function () {
                        if (typeof window.onCreateClick === 'function') window.onCreateClick();
                    }
                });

                // ── Run button (disabled until a job is created) ──────────────
                new DevExpress.ui.dxButton(document.getElementById('btnRun'), {
                    text: 'Run',
                    type: 'success',
                    disabled: true,
                    onClick: function () {
                        if (typeof window.onRunClick === 'function') window.onRunClick();
                    }
                });

                // ── Cancel button ─────────────────────────────────────────────
                new DevExpress.ui.dxButton(document.getElementById('btnCancel'), {
                    text: 'Cancel',
                    type: 'danger',
                    disabled: true,
                    onClick: function () {
                        if (typeof window.onCancelClick === 'function') window.onCancelClick();
                    }
                });

                // ── Logout button ─────────────────────────────────────────────
                new DevExpress.ui.dxButton(document.getElementById('btnLogout'), {
                    text: 'Logout',
                    type: 'normal',
                    onClick: function () {
                        if (typeof window.onLogoutClick === 'function') window.onLogoutClick();
                    }
                });

                // ── Main tab panel: Program / Output / Files / Log ──────────
                new DevExpress.ui.dxTabPanel(document.getElementById('mainTabPanel'), {
                    items: [
                        {
                            title: 'Program',
                            template: function () {
                                return '<div id="monacoContainer"></div>';
                            }
                        },
                        {
                            title: 'Output',
                            template: function () {
                                return '<div class="tab-pane-output"><em>Output will appear here after the job completes.</em></div>';
                            }
                        },
                        {
                            title: 'Files',
                            template: function () {
                                return '<div class="tab-pane-files"><em>Generated files will be listed here.</em></div>';
                            }
                        },
                        {
                            title: 'Log',
                            template: function () { return '<pre id="logContent"></pre>'; }
                        }
                    ],
                    selectedIndex: 0,
                    animationEnabled: false
                });
            } catch (e) {
                console.error('DevExtreme widget init failed:', e);
            }
        });
    </script>

    @* Monaco Editor CDN loader *@
    <script src="https://cdn.jsdelivr.net/npm/monaco-editor@0.52.0/min/vs/loader.js"></script>

    @* Configure Output client logic *@
    <script src="~/js/configure-output.js" asp-append-version="true"></script>
}
